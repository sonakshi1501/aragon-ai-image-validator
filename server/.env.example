PORT=3001
DATABASE_URL="postgresql://aragon:aragon@localhost:5432/aragon_images?schema=public"

# S3 / MinIO (leave empty to use local ./uploads fallback)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=aragon-images
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/aragon-images

# Validation thresholds
MIN_WIDTH=400
MIN_HEIGHT=400
MIN_FILE_SIZE_BYTES=50000
MAX_SIMILAR_HAMMING_DISTANCE=5
MIN_BLUR_VARIANCE=100
MIN_FACE_AREA_RATIO=0.05
MAX_FACE_COUNT=1
